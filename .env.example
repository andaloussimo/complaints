# ─── Build-time (the ONLY per-site build input) ─────────────────────────────
# Points to a folder under sites/<SITE>/ (content.json, theme.json, assets/).
# Everything else about a site — form language, canonical URL — lives in that
# site's content.json (meta.formLang, meta.siteUrl).
SITE=demo

# ─── Runtime secrets — NOT used at build ────────────────────────────────────
# These are read by the Cloudflare Pages Function (functions/api/refund.ts) at
# request time. In production set them per Pages project (dashboard or
# `wrangler pages secret put HUBSPOT_TOKEN --project-name=<slug>`).
# For LOCAL testing put them in .dev.vars (see .dev.vars.example) and run
# `npm run preview`.
HUBSPOT_TOKEN=
HUBSPOT_PIPELINE=
HUBSPOT_STAGE=
HUBSPOT_OWNER=
HUBSPOT_PRIORITY=            # LOW | MEDIUM | HIGH
HUBSPOT_ROUTING_PROP=
HUBSPOT_ROUTING_VALUE=
HUBSPOT_OPERATOR_PROP=
HUBSPOT_OPERATOR_CODE=
HUBSPOT_ORIGIN_PROP=ticketorigin
HUBSPOT_ORIGIN_VALUE=nextjs
